{
    "rng": [
        
        {
            "name": "D20",        
            "start": 1,
            "end": 20,
            "step": 1,
            "rule": ":ns:n",
            "fixed-value": 10
        },

        {
            "name": "Fibonacci",
            "rule": ":ns:(n-1)+(n-2)",
            "start": 1,
            "end": 10
        },

        {
            "name": "Fibonacci Native",
            "rule": ":nsr:fibo",
            "start": 1,
            "end": 10
        },

        {
            "name": "arbitrary numbers",
            "values": [1,5,1,1,2,3,8]
        }

    ]
}