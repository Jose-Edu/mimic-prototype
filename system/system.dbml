Table roles {
  id_role integer [primary key]
  name varchar unique
  is_default bool
  roleless_add bool
}

Table access {
  id_access integer [primary key]
  id_entity integer /*nullable*/
  id_game_state integer /*nullable*/
  scope enum("self", "same", "other")
  action bitmask("read", "use", "update", "create", "delete", "overwrite")
}

Table role_access {
  id_access integer [primary key]
  id_role integer [primary key]
}

Table sheet_types {
  id_sheet_type integer [primary key]
  name varchar unique
  id_validation_rule integer
}

Table sheets {
  id_sheet integer [primary key]
  id_sheet_type integer
  data json
  x_size integer
  y_size integer
  z_size integer
  origin integer
}

Table generator_types {
  id_generator_type integer [primary key]
  name varchar unique
  schema json
}

Table generators {
  id_generator integer [primary key]
  id_generator_type integer
  name varchar unique
  data json
}

Table sheet_type_generator_type {
  id_sheet_type integer [primary key]
  id_generator_type integer [primary key]
}

Table skill_types {
  id_skill_type integer [primary key]
  name varchar unique
  id_validation_rule integer
}

Table skills {
  id_skill integer [primary key]
  id_skill_type integer
  name varchar
  id_action_rule integer
}

Table skill_type_generator_type {
  id_skill_type integer [primary key]
  id_generator_type integer [primary key]
}

Table rules {
  id_rule integer [primary key]
  name varchar
  type varchar
  rule json
}

Table rngs {
  id_rng integer [primary key]
  name varchar unique
  expected_value integer /*nullable*/
  filter_rule_id integer /*nullable*/
  generator_start integer /*nullable default 1*/
  generator_end integer
  generator_step integer /*nullable default 1*/
  cached_values integer[]
}

Table atributes {
  id_atribute integer [primary key]
  name varchar unique
  id_value_rule integer
  value_type enum("int", "string")
  default_value varchar /*nullable*/
}

Table atribute_items {
  id_atribute_item integer [primary key]
  id_atribute integer
  name varchar
  type enum("int", "string")
}

Table globals {
  id_global integer [primary key]
  id_atribute integer
  name varchar unique
  is_constant bool
}

Table tests {
  id_test integer [primary key]
  name varchar unique
  id_rule integer
}

Table test_atribute {
  id_test integer [primary key]
  id_atribute integer [primary key]
}

Table test_rng {
  id_test integer [primary key]
  id_rng integer [primary key]
}

Table atribute_generator_type {
  id_atribute integer [primary key]
  id_generator_type integer [primary key]
}

Table game_states {
  id_game_state integer [primary key]
  name varchar unique
  turn_count_rule_id integer
  turn_order_rule_id integer
}

Table system_info {
  id_system_info integer [primary key]
  mimic_version_l1 integer
  mimic_version_l2 integer
  mimic_version_l3 integer
  system_name varchar
  system_version_l1 varchar
  system_version_l2 varchar
  system_version_l3 varchar
  system_author varchar
  system_hash varchar
}

Table tags {
  id_tag integer [primary key]
  id_entity integer
  name varchar unique
}

Table entities {
  id_entity integer [primary key]
  table_name varchar
  intern_id integer
}

Table maps {
  id_map integer [primary key]
  name varchar unique
  x_size integer
  y_size integer
  z_size integer
}

Table map_sheet {

  id_map_sheet integer
  id_sheet integer
  id_map integer
  x integer
  y integer
  z integer

}

Ref: "rngs"."id_rng" < "test_rng"."id_rng"

Ref: "tests"."id_test" < "test_rng"."id_test"

Ref: "tests"."id_test" < "test_atribute"."id_test"

Ref: "atributes"."id_atribute" < "test_atribute"."id_atribute"

Ref: "atributes"."id_atribute" < "globals"."id_atribute"

Ref: "atributes"."id_atribute" < "atribute_generator_type"."id_atribute"

Ref: "skills"."id_skill" < "skill_type_generator_type"."id_skill_type"

Ref: "roles"."id_role" < "role_access"."id_role"

Ref: "access"."id_access" < "role_access"."id_access"

Ref: "skills"."id_skill_type" <
"skill_types"."id_skill_type"

Ref: "generators"."id_generator_type" <
"generator_types"."id_generator_type"

Ref: "sheet_type_generator_type"."id_generator_type" > "generator_types"."id_generator_type"

Ref: "atribute_generator_type"."id_generator_type" >
"generator_types"."id_generator_type"

Ref: "skill_type_generator_type"."id_generator_type" >
"generator_types"."id_generator_type"

Ref: "sheet_type_generator_type"."id_sheet_type" >
"sheet_types"."id_sheet_type"

Ref: "access"."id_entity" >
"entities"."id_entity"

Ref: "access"."id_game_state" >
"game_states"."id_game_state"

Ref: "tags"."id_entity" >
"entities"."id_entity"

Ref: "tests"."id_rule" >
"rules"."id_rule"

Ref: "rngs"."filter_rule_id" >
"rules"."id_rule"

Ref: "atributes"."id_value_rule" >
"rules"."id_rule"

Ref: "sheet_types"."id_validation_rule" >
"rules"."id_rule"

Ref: "skill_types"."id_validation_rule" >
"rules"."id_rule"

Ref: "skills"."id_action_rule" >
"rules"."id_rule"

Ref: "atribute_items"."id_atribute" >
"atributes"."id_atribute"

Ref: "game_states"."turn_count_rule_id" >
"rules"."id_rule"

Ref: "game_states"."turn_order_rule_id" >
"rules"."id_rule"

Ref: "map_sheet"."id_map" >
"maps"."id_map"

Ref: "map_sheet"."id_sheet" >
"sheets"."id_sheet"

Ref: "sheets"."id_sheet_type" >
"sheet_types"."id_sheet_type"